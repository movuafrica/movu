# ── EC2 / Docker Compose ─────────────────────────────────────────────────────
# The GitHub repository slug (owner/repo), used to pull images from GHCR.
# Example: myorg/movu
GITHUB_REPOSITORY=

# Your production domain — Caddy will obtain a Let's Encrypt cert automatically.
# Example: movu.example.com
DOMAIN=

# ── Database (AWS Aurora PostgreSQL) ─────────────────────────────────────────
# Aurora cluster writer endpoint connection string.
# Example: postgresql://movu:strongpassword@cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/movu
DATABASE_URL=

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Production secret key from Clerk dashboard.
CLERK_SECRET_KEY=

# Production JWT key (from Clerk dashboard → API Keys → Advanced).
# Used by the API to verify tokens without a network round-trip.
CLERK_JWT_KEY=

# Comma-separated list of allowed origins for Clerk token verification.
# Should include your production domain.
# Example: https://your-domain.com
CLERK_AUTHORIZED_PARTIES=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── RAG Service ───────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the RAG service.
# Should match your production web domain.
# Example: https://your-domain.com
CORS_ORIGINS=https://your-domain.com
