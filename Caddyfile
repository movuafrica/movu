# Caddyfile
#
# Caddy handles TLS automatically via Let's Encrypt — no certbot needed.
# Set the DOMAIN env var on your EC2 instance (e.g. DOMAIN=api.movu.example.com).
#
# The web app is deployed on Vercel and calls these services over the public internet.
# Both the API and RAG service are exposed here; no other service is reachable publicly.

{$DOMAIN:localhost} {

    # NestJS API — strip /api prefix before forwarding
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3001
    }

    # FastAPI RAG service — strip /rag prefix before forwarding
    handle /rag/* {
        uri strip_prefix /rag
        reverse_proxy rag:8000
    }

    # Drizzle Studio — protected with basic auth
    handle /drizzle* {
        basicauth {
            admin $2a$14$t6o./sS5Tq6RN4i59AFC9eRzL99LZ.WhijnVffwNlHA60j54.JS02
        }
        reverse_proxy drizzle-studio:4983
    }
}
